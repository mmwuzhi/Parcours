# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://parcours:parcours@localhost:5432/parcours

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000

# ── Web ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
WEB_PORT=3000

# ── Sentry (optional in development) ─────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── AI Analysis ───────────────────────────────────────────────────────────────
# Provider: openai | anthropic | google | groq | mistral | deepseek
# AI_BASE_URL is optional — use for OpenAI-compatible endpoints (Ollama, etc.)
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o
AI_BASE_URL=

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
