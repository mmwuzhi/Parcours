# Copy this file to .env and fill in the values.
# Generate secrets with: openssl rand -base64 64

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://parcours:parcours@localhost:5432/parcours

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── AI Analysis ───────────────────────────────────────────────────────────────
# Provider: openai | anthropic | google | groq | mistral | deepseek
# Set AI_BASE_URL to use any OpenAI-compatible endpoint (Ollama, local models, etc.)
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o
AI_BASE_URL=

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Sentry (optional) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
