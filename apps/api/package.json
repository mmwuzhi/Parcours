{
  "name": "@parcours/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../../.env --import tsx/esm --watch src/index.ts",
    "build": "tsup",
    "start": "node apps/api/dist/index.js",
    "test": "vitest run",
    "test:api": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "@hono/zod-openapi": "^1.3.0",
    "@hono/swagger-ui": "^0.6.1",
    "@parcours/shared": "workspace:*",
    "ai": "^6.0.174",
    "@ai-sdk/openai": "^3.0.58",
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/google": "^3.0.67",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "bcrypt": "^6.0.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "supertest": "^7.2.2",
    "@types/supertest": "^7.2.0"
  }
}
